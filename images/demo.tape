Output images/demo.gif
Set FontSize 18
Set Width 1400
Set Height 900
Set Theme "Builtin Solarized Dark"
Set TypingSpeed 40ms
Set Shell "bash"

Type "cd /home/s3/go-jmp.nigelhamilton.com"
Enter
Sleep 500ms

# Show version
Type "jmp version"
Enter
Sleep 1.5s

# Show help — the three verbs
Type "jmp help"
Enter
Sleep 5s

# jmp in — search in files for keywords
Type "jmp in 'FindFiles'"
Enter
Sleep 4s
Down
Sleep 500ms
Down
Sleep 500ms
Down
Sleep 500ms
Right
Sleep 3s
Type "q"
Sleep 1s
